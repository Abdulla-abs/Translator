    <string name="resmulti_about_title">What is KMP Translator?</string>
    <string name="resmulti_about_desc">KMP Translator is a localization resource suite for Kotlin Multiplatform and Android developers. Re-import strings.xml tables, co-localize multiple values, and use AI to translate blank cells on demand.</string>
    <string name="resmulti_about_feature_ai">Gemini-Cognitive Translation</string>
    <string name="resmulti_about_feature_ai_desc">AI analyzes key context and the target locale to deliver natural local translations.</string>
    <string name="resmulti_about_feature_xml">KMP / Android XML Aligned</string>
    <string name="resmulti_about_feature_xml_desc">Engineered around standard Android resource directories like values, values-ab, and values-es.</string>
    <string name="resmulti_about_howto_title">How to Localize Compose String Resources</string>
    <string name="resmulti_about_howto_step1">Step 1: Declare key-value strings inside local KMP sheets</string>
    <string name="resmulti_about_howto_step2">Step 2: Sync and translate using the Translate tab. Use AI Translate on blank cells or bulk translate missing outputs.</string>
    <string name="resmulti_about_howto_step3">Step 3: Export finalized spreadsheets and load them back into the project resource root.</string>
    <string name="resmulti_about_footer">Made for Kotlin Developers with</string>
    <string name="resmulti_not_ready_hint">Import resources from the Files tab first.</string>

